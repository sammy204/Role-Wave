--- /dev/null
+++ b/src/components/ProfileSectionCard.tsx
@@ -0,0 +1,53 @@
+import type { ReactNode } from 'react';
+import { Pencil, Plus } from 'lucide-react';
+
+type ProfileSectionCardProps = {
+  title: string;
+  isEmpty: boolean;
+  emptyLabel: string;
+  onEdit: () => void;
+  children: ReactNode;
+};
+
+export default function ProfileSectionCard({
+  title,
+  isEmpty,
+  emptyLabel,
+  onEdit,
+  children,
+}: ProfileSectionCardProps) {
+  if (isEmpty) {
+    return (
+      <button
+        type="button"
+        onClick={onEdit}
+        className="group flex w-full items-center justify-between rounded-[28px] border border-dashed border-[#D3D1C7] bg-[#FBFAF7] p-5 text-left transition-colors hover:border-[#1D9E75] hover:bg-[#F3FBF8]"
+      >
+        <div>
+          <div className="mb-1 text-sm font-semibold text-[#1A1A1A]">{title}</div>
+          <div className="text-sm text-[#5F5E5A]">{emptyLabel}</div>
+        </div>
+        <span className="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-[#D3D1C7] bg-white text-[#1D9E75] group-hover:border-[#1D9E75]">
+          <Plus size={16} />
+        </span>
+      </button>
+    );
+  }
+
+  return (
+    <div className="group panel rounded-[28px] p-5">
+      <div className="mb-3 flex items-center justify-between">
+        <div className="text-sm font-semibold text-[#1A1A1A]">{title}</div>
+        <button
+          type="button"
+          onClick={onEdit}
+          aria-label={`Edit ${title}`}
+          className="flex h-8 w-8 items-center justify-center rounded-full text-[#5F5E5A] opacity-100 transition-opacity hover:bg-[#F1EFE8] sm:opacity-0 sm:group-hover:opacity-100 sm:focus:opacity-100"
+        >
+          <Pencil size={14} />
+        </button>
+      </div>
+      {children}
+    </div>
+  );
+}
