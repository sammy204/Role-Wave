@@ -0,0 +1,15 @@
+/*
+The candidate profile form and its TypeScript type reference a
+visibility_to_employers column that was never added to the table,
+causing 400 errors on candidate_profiles upsert.
+*/
+
+ALTER TABLE public.candidate_profiles
+  ADD COLUMN IF NOT EXISTS visibility_to_employers text NOT NULL DEFAULT 'open';
+
+ALTER TABLE public.candidate_profiles
+  DROP CONSTRAINT IF EXISTS candidate_profiles_visibility_check;
+
+ALTER TABLE public.candidate_profiles
+  ADD CONSTRAINT candidate_profiles_visibility_check
+  CHECK (visibility_to_employers IN ('open', 'not_open', 'hidden'));
